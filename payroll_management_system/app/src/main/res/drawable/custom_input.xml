<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Focused state (when clicked) -->
    <item android:state_focused="true">
        <shape>
            <solid android:color="#F5F5F5"/> <!-- light grey background -->
            <stroke
                android:width="2dp"
                android:color="#D3D3D3"/> <!-- soft grey border -->
            <corners android:radius="10dp"/>
        </shape>
    </item>

    <!-- Default state -->
    <item>
        <shape>
            <solid android:color="?android:attr/colorBackground"/> <!-- normal light -->
            <stroke
                android:width="1dp"
                android:color="?attr/colorControlHighlight"/>
            <corners android:radius="10dp"/>
        </shape>
    </item>

</selector>