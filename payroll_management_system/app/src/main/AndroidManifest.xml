<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.example.myapplication">

    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:name=".MyApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.MyApplication"
        android:usesCleartextTraffic="true">

        <!-- ================= MAIN ACTIVITY ================= -->
        <activity
            android:name=".view.MainActivity"
            android:exported="true">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

        </activity>

        <!-- ================= OTHER ACTIVITIES ================= -->

        <activity
            android:name=".view.Calender"
            android:exported="false" />

        <activity
            android:name=".view.SecondActivity"
            android:exported="true" />

        <!-- Payslip -->
        <activity
            android:name=".view.PayslipActivity"
            android:exported="false" />

        <activity
            android:name=".view.FilterPayslipActivity"
            android:exported="false" />

        <!-- Leave -->
        <activity
            android:name=".view.LeaveRequestActivity"
            android:exported="false" />

        <activity
            android:name=".view.ApplyLeaveActivity"
            android:exported="false" />

        <!-- Payroll -->
        <activity
            android:name=".view.PayrollHistoryActivity"
            android:exported="false" />

        <!-- Holidays -->
        <activity
            android:name=".view.HolidayActivity"
            android:exported="false" />

        <!-- Profile -->
        <activity
            android:name=".view.ProfileActivity"
            android:exported="false" />

        <!-- Salary Overview -->
        <activity
            android:name=".view.SalaryOverviewActivity"
            android:exported="false" />

        <!-- ================= FILE PROVIDER ================= -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.provider"
            android:exported="false"
            android:grantUriPermissions="true">

            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />

        </provider>

    </application>

</manifest>